VALIDATE_ALL_CODEBASE=true
VALIDATE_CPP=false
VALIDATE_JSCPD=false
VALIDATE_TYPESCRIPT=false
VALIDATE_TYPESCRIPT_ES=false
VALIDATE_TYPESCRIPT_PRETTIER=false
VALIDATE_TYPESCRIPT_STANDARD=false
# Exclude translation files: codespell isn't language-aware and flags genuine
# non-English words (Afrikaans `te`, `Alle`, `leeg`; etc.) as English
# misspellings. The .codespellrc `skip` directive doesn't work here because
# super-linter passes individual files to codespell, bypassing its
# file-discovery layer.
FILTER_REGEX_EXCLUDE=^localization/
